{
  "name": "@icjia/forgecrawl",
  "version": "0.1.7",
  "description": "MCP web-scraping server for Claude Code — fetches URLs, runs Mozilla Readability, and returns clean Markdown optimized for Claude's context window. Works with SPAs via headless Chromium.",
  "type": "module",
  "main": "src/server.js",
  "bin": {
    "forgecrawl": "src/cli.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "node --test test/*.test.js",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "files": [
    "src/",
    "scripts/postinstall.mjs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "scraper",
    "scraping",
    "crawler",
    "markdown",
    "readability",
    "turndown",
    "playwright",
    "spa",
    "claude",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ICJIA/forgecrawl-mcp.git"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.0.0",
    "commander": "^14.0.3",
    "linkedom": "^0.18.0",
    "playwright": "^1.49.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^4.3.6"
  }
}
